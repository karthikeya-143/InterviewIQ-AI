# InterviewIQ AI Configuration

# FastAPI Server settings
HOST=127.0.0.1
PORT=8000

# AI Models settings (Optional overrides)
# Whisper speech transcription model name (e.g., openai/whisper-tiny)
WHISPER_MODEL=openai/whisper-tiny

# Sentence-BERT similarity model name (e.g., all-MiniLM-L6-v2)
SBERT_MODEL=all-MiniLM-L6-v2

# Flan-T5 text generator model name (e.g., google/flan-t5-small)
GENERATOR_MODEL=google/flan-t5-small

# Set to 1 to suppress Hugging Face Hub cache warning flags on Windows
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Frontend API base URL (optional — defaults to /api via Vite proxy)
# VITE_API_BASE_URL=http://127.0.0.1:8000/api
